# Secrets & environnement — JAMAIS de .env commité (règle n°5)
.env
.env.*
!.env.example

# Python
.venv/
venv/
__pycache__/
*.pyc
*.egg-info/
.pytest_cache/
.ruff_cache/
build/
dist/

# Node / extension (WXT)
node_modules/
extension/.output/
extension/.wxt/

# Sorties générées
report/out/
out/

# Routeur (Lot B) : artefacts de modèles ignorés (R5, potentiellement gros),
# petits rapports (bench, éval) VERSIONNÉS — cf. router/CONVERGENCE_LEDGER.md.
# router/artifacts/models/ (candidate/promoted/previous, spec R5 §8) : JAMAIS
# commité — l'identité versionnée vit DANS metadata.json (hash corpus, hash
# artefacts, best_iteration) et l'artefact est régénérable (train déterministe
# bit-exact, corpus épinglé). Couvert par le motif ci-dessous (aucune
# exception ajoutée pour models/).
# R6 (spec §1.2/§4.2) : router/artifacts/embed/ — encodeur ONNX téléchargé
# (encoder/model.onnx ~110-130 Mo + tokenizer.json) et têtes
# (heads/{candidate,promoted,previous}) — est COUVERT par le motif
# router/artifacts/* ci-dessous (seuls bench/ et eval/ sont exceptés) :
# le modèle n'est JAMAIS commité, aucune exception ajoutée pour embed/.
router/artifacts/*
!router/artifacts/bench/
!router/artifacts/bench/*
!router/artifacts/eval/
!router/artifacts/eval/*
# Corpus synthétique R4 (démarrage à froid) : régénérable au seed près
# (DEFAULT_SEED=4242, router/data/generate_corpus.py) — jamais commité
# (peut atteindre plusieurs dizaines de Mo). Seuls le générateur et les
# petits JSON (metadata/stats/quality/bruit) d'un run de RÉFÉRENCE sont
# versionnés, dans router/data/reference/ (cible `make router-corpus`).
router/data/artifacts/
# Exception : captures visuelles FINALES versionnées de l'extension (le
# répertoire out/ générique les attraperait sinon). L'extension/.gitignore
# ignore le reste de out/ et ne garde que final/.
!extension/test/visual/out/
!extension/test/visual/out/final/

# macOS / IDE
.DS_Store
.idea/
.vscode/

# Graphe de code local (graphify) — régénéré à chaque commit, jamais versionné.
graphify-out/
