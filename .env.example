# Sobrio — variables d'environnement de développement.
# Copier vers .env (gitignoré) : cp .env.example .env
# RÈGLE n°5 : aucune valeur réelle ici. Jamais de secret commité.

# --- PostgreSQL (docker-compose.dev.yml) ---
POSTGRES_USER=sobrio
POSTGRES_PASSWORD=sobrio_dev_password
POSTGRES_DB=sobrio
DATABASE_URL=postgresql+psycopg://sobrio:sobrio_dev_password@localhost:5432/sobrio

# --- API ---
SOBRIO_API_PORT=8000
# Token de l'org de démo (dev uniquement — valeur factice, pas un secret)
DEMO_ORG_TOKEN=demo-token-not-a-secret
# SOBRIO_EMBED_STAGE2 : étage 2 embeddings (R6) — défaut : DÉSACTIVÉ.
# Volontairement NON posé ici (verrou 1 du triple verrou, spec R6 §3.1) :
# "1" exactement pour l'ouvrir, toute autre valeur = fermé. Jamais en CI.

# --- Connecteur ---
# Sel de pseudonymisation (hash salé des identifiants utilisateurs — règle n°1)
PSEUDONYM_SALT=dev-salt-change-me

# Clé d'administration Anthropic — ACTIF CRITIQUE (règle n°5).
# Anthropic n'offre pas de permission fine : cette clé lit TOUT le compte.
# Lue depuis l'environnement uniquement. Jamais commitée, jamais loggée.
# Rotation : voir connector/README.md.
ANTHROPIC_ADMIN_KEY=

# --- Rapport / impact ---
# Chemin du catalogue de modèles (défaut : contracts/model_catalog.yaml)
# MODEL_CATALOG_PATH=
